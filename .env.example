# ローカル開発用（Lambda では SSM Parameter Store から読み込むため不要）
TESLA_CLIENT_ID=your_client_id_here
TESLA_CLIENT_SECRET=your_client_secret_here

# deploy_skill.py 単独実行用（./scripts/deploy 経由なら不要）
HALSTELA_DEV_LAMBDA_ARN=arn:aws:lambda:us-west-2:012345678901:function:halstela-skill
HALSTELA_PRD_LAMBDA_ARN=arn:aws:lambda:us-west-2:012345678901:function:halstela-skill
